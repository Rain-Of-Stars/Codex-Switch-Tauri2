{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Codex Switch",
  "version": "1.4.0",
  "identifier": "com.codexswitch.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "node ./tooling/scripts/tauri-before-build.cjs",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Codex Switch",
        "width": 1480,
        "height": 980,
        "minWidth": 1280,
        "minHeight": 840,
        "resizable": true,
        "fullscreen": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "category": "DeveloperTool",
    "targets": ["nsis"],
    "shortDescription": "Codex 配置切换与备份恢复桌面控制台",
    "longDescription": "用于管理 Codex 配置组合、Windows 与 WSL 目标切换、模板编辑、连接测试、备份恢复和 sessions/state_5.sqlite 迁移。",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ],
    "windows": {
      "digestAlgorithm": "sha256",
      "nsis": {
        "installerIcon": "icons/icon.ico"
      }
    }
  }
}
