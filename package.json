{
  "name": "codex-switch-tauri",
  "private": true,
  "version": "1.3.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "check:sensitive-paths": "node ./tooling/scripts/check-sensitive-paths.cjs",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "build": "npm run typecheck && npm run build:dist",
    "build:dist": "vite build",
    "preview": "vite preview",
    "clean:artifacts": "node ./tooling/scripts/clean-artifacts.cjs",
    "clean:all": "node ./tooling/scripts/clean-artifacts.cjs --with-node-modules",
    "tauri": "node ./tooling/scripts/run-in-msvc-env.cjs tauri",
    "build:windows": "node ./tooling/scripts/run-in-msvc-env.cjs tauri build --bundles nsis",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:rust": "node ./tooling/scripts/run-in-msvc-env.cjs cargo test --manifest-path src-tauri/Cargo.toml",
    "check:rust": "node ./tooling/scripts/run-in-msvc-env.cjs cargo check --manifest-path src-tauri/Cargo.toml",
    "verify": "npm run check:sensitive-paths && npm run test && npm run typecheck && npm run test:rust && npm run check:rust"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tauri-apps/api": "^2.10.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.553.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.66.0",
    "react-router-dom": "^7.9.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "zod": "^4.1.12",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.17",
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.7.2",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.0.4",
    "jsdom": "^27.0.0",
    "tailwindcss": "^4.1.17",
    "typescript": "^5.9.3",
    "vite": "^8.0.3",
    "vitest": "^3.2.4"
  }
}
